# QoE Normalizer — 환경변수 예시 (키 이름만, 값은 비워둠)
#
# 웹앱을 쓰면 이 파일은 필요 없습니다. 키는 브라우저 화면에서 입력하고 메모리에만 둡니다.
# 이 파일은 CLI 로 직접 파이프라인을 돌릴 때만 쓰는 선택 사항입니다.
#
# 사용 시: 이 파일을 .env 로 복사하고 값을 채운 뒤 셸에서 로드하세요.
#   cp .env.example .env      (그리고 값 입력)
#   set -a && source .env && set +a
#
# 주의: 값이 채워진 .env 는 절대 커밋하지 마세요(.gitignore 에 이미 제외).

# OpenDART API 키 — 무료. 발급: https://opendart.fss.or.kr/
OPENDART_API_KEY=

# Anthropic API 키 — 유료(소액). 발급: https://console.anthropic.com/
ANTHROPIC_API_KEY=
